{
  "name": "@snabbsajt/site-kit",
  "version": "0.2.0",
  "description": "Build, validate, and pack editable SnabbSajt site packages.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HH-Studio/Sajtbuilder-SDK.git#v0.2.0"
  },
  "homepage": "https://snabbsajt.com/docs/en/developer/site-kit",
  "bugs": "https://github.com/HH-Studio/Sajtbuilder-SDK/issues",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "site-kit": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./local-files": {
      "types": "./dist/lib/site-kit/localFiles.d.ts",
      "import": "./dist/lib/site-kit/localFiles.js"
    }
  },
  "files": [
    "dist",
    "contract",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run build:site-kit && bun run --cwd packages/cli build",
    "build:site-kit": "tsup src/index.ts src/cli.ts src/lib/site-kit/localFiles.ts --format esm --dts --clean && mkdir -p packages/site-kit/dist && cp -R dist/. packages/site-kit/dist/",
    "test": "vitest run && bun run --cwd packages/cli test",
    "typecheck": "tsc --noEmit && bun run --cwd packages/cli typecheck",
    "contract:check": "bun scripts/sync-contract.ts --check",
    "release:assets": "bun scripts/package-skill-assets.ts",
    "check": "bun run build && bun run typecheck && bun run test && bun run contract:check",
    "prepare": "npm run build"
  },
  "dependencies": {
    "convex": "^1.42.0",
    "convex-helpers": "^0.1.120",
    "css-tree": "^3.2.1",
    "fflate": "^0.8.3",
    "fractional-indexing": "^3.4.0",
    "parse5": "^8.0.1",
    "saxes": "^6.0.0"
  },
  "devDependencies": {
    "@types/css-tree": "^2.3.11",
    "@types/node": "^24.13.2",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
